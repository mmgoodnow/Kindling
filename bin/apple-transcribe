#!/bin/zsh
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"
SOURCE_FILE="$ROOT_DIR/scratch/AppleTranscriptionPlayground.swift"
BUILD_DIR="$ROOT_DIR/.build"
BINARY="$BUILD_DIR/apple-transcription-playground"

mkdir -p "$BUILD_DIR"

if [[ ! -x "$BINARY" || "$SOURCE_FILE" -nt "$BINARY" ]]; then
  swiftc -parse-as-library "$SOURCE_FILE" -o "$BINARY"
fi

exec "$BINARY" "$@"
